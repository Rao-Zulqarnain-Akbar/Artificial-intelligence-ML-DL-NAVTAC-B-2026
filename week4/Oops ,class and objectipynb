    "        print(\"Course:\", self.course)\n",
    "        print(\"Marks:\", self.marks)\n",
    "\n",
    "    # Object Method 2\n",
    "    def check_pass(self):\n",
    "        if self.marks >= 50:\n",
    "            print(self.name, \"has passed\")\n",
    "        else:\n",
    "            print(self.name, \"has failed\")\n",
    "\n",
